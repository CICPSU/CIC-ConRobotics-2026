<?xml version="1.0" ?>
<robot name="excavator_scan_model">

  <link name="base_link">
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.01 0.01 0.01"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <box size="0.01 0.01 0.01"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="track_link"/>
    <origin xyz="0 0 0.054" rpy="0 0 0"/>
  </joint>

  <link name="track_link">
    <inertial>
      <mass value="0.30"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.002" ixy="0.0" ixz="0.0" iyy="0.002" iyz="0.0" izz="0.002"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="./meshes/Bottom.obj" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.20 0.12 0.05"/>
      </geometry>
    </collision>
  </link>

  <joint name="swing_joint" type="continuous">
    <parent link="track_link"/>
    <child link="body_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="body_link">
    <inertial>
      <mass value="0.15"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0005" ixy="0.0" ixz="0.0" iyy="0.0005" iyz="0.0" izz="0.0005"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="./meshes/Body.obj" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.12 0.08 0.06"/>
      </geometry>
    </collision>
  </link>

  <joint name="boom_joint" type="revolute">
    <parent link="body_link"/>
    <child link="boom_link"/>
    <origin xyz="-0.012 -0.005 0.027" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.5" upper="0.5" effort="5" velocity="2.0"/>
  </joint>

  <link name="boom_link">
    <inertial>
      <mass value="0.08"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0002" ixy="0.0" ixz="0.0" iyy="0.0002" iyz="0.0" izz="0.0002"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="./meshes/Boom.obj" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0.05 0 0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.14 0.03 0.03"/>
      </geometry>
    </collision>
  </link>

  <joint name="arm_joint" type="revolute">
    <parent link="boom_link"/>
    <child link="arm_link"/>
    <origin xyz="-0.010 -0.22 0.102" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.5" upper="1.5" effort="5" velocity="2.0"/>
  </joint>

  <link name="arm_link">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="./meshes/Arm.obj" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0.04 0 0.015" rpy="0 0 0"/>
      <geometry>
        <box size="0.10 0.025 0.025"/>
      </geometry>
    </collision>
  </link>

  <joint name="bucket_joint" type="revolute">
    <parent link="arm_link"/>
    <child link="bucket_link"/>
    <origin xyz="-0.007 -0.064 -0.095" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.5" upper="1.5" effort="5" velocity="2.0"/>
  </joint>

  <link name="bucket_link">
    <inertial>
      <mass value="0.03"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00005" ixy="0.0" ixz="0.0" iyy="0.00005" iyz="0.0" izz="0.00005"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="./meshes/Bucket.obj" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.05 0.04"/>
      </geometry>
    </collision>
  </link>

</robot>
